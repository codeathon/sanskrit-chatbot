# Bytecode / caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Environment variables (never commit secrets)
.env
.env.*
!.env.example

# Local virtualenv — python3 -m venv venv && pip install -r requirements.txt
venv/
.venv/

# Node (if used)
node_modules/

# Corpus files in data/ stay local; the folder is tracked via data/.gitkeep only.
data/*
!data/.gitkeep
